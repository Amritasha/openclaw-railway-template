# Password to access the /setup wizard
# Generate a strong one: openssl rand -base64 18
SETUP_PASSWORD=change-me

# Persistent state directory — MUST be inside /data (Railway volume)
OPENCLAW_STATE_DIR=/data/.openclaw

# Workspace directory — MUST be inside /data
OPENCLAW_WORKSPACE_DIR=/data/workspace

# Admin token for the openclaw gateway
# Generate: openssl rand -hex 32
# If unset, a random token is generated per restart (not ideal for production)
OPENCLAW_GATEWAY_TOKEN=

# Internal port the openclaw gateway binds to (proxied by the wrapper)
INTERNAL_GATEWAY_PORT=18789

# Public port Railway routes to (set automatically by Railway)
PORT=8080
